#!/bin/sh

repo_root="$(git rev-parse --show-toplevel)"
script_path="$repo_root\\scripts\\agent-task-complete.ps1"

task="${AGENT_NOTIFY_TASK:-unspecified-task}"
message="${AGENT_NOTIFY_MESSAGE:-New commit is ready for review.}"
from="${AGENT_NOTIFY_FROM:-impl-agent}"
to="${AGENT_NOTIFY_TO:-pm-agent}"

if [ ! -f "$repo_root/scripts/agent-task-complete.ps1" ]; then
  exit 0
fi

powershell.exe -ExecutionPolicy Bypass -File "$script_path" -Task "$task" -Message "$message" -From "$from" -To "$to" > /dev/null 2>&1 || exit 0
